# Tidak wajib diisi — halaman stock bisa diakses tanpa login.
# Hanya diperlukan jika fitur login Playwright diaktifkan kembali di masa depan.
LM_EMAIL=
LM_PASSWORD=
# Kosongkan untuk scrape SEMUA butik yang tersedia secara otomatis.
# Isi dengan kode butik (dipisah koma) untuk membatasi ke butik tertentu.
# Bisa juga pakai substring nama, contoh: Pulogadung,Bandung
#
# Daftar kode butik yang tersedia (per 2026-05-14):
#   ABDH   = BELM - Pengiriman Ekspedisi, Pulogadung Jakarta, Jakarta
#   AGDP   = BELM - Graha Dipta (Pengambilan Di Butik) Pulo Gadung, Jakarta
#   AJK2   = BELM - Gedung Antam (pengambilan Di Butik), Jakarta
#   AJK4   = BELM - Setiabudi One (pengambilan Di Butik), Jakarta
#   JKT05  = BELM - Juanda, Jakarta
#   JKT06  = BELM - Puri Indah, Jakarta
#   ABDG   = BELM - Bandung, Bandung
#   ASMG   = BELM - Semarang, Semarang
#   AJOG   = BELM - Yogyakarta, Yogyakarta
#   ASB1   = BELM - Surabaya Darmo, Surabaya
#   ASB2   = BELM - Surabaya Pakuwon, Surabaya
#   ADPS   = BELM - Denpasar Bali, Bali
#   ABPN   = BELM - Balikpapan, Balikpapan
#   AMKS   = BELM - Makassar, Makassar
#   AKNO   = BELM - Medan, Medan
#   APLG   = BELM - Palembang, Palembang
#   APKU   = BELM - Pekanbaru, Pekanbaru
#   ABSD   = BELM - Serpong (pengambilan Di Butik), Tangerang
#   BTR01  = BELM - Bintaro, Tangerang Selatan
#   BGR01  = BELM - Bogor, Bogor
#   BKS01  = BELM - Bekasi, Bekasi
#
# Contoh: hanya Jakarta Ekspedisi + Bandung
# LM_TARGET_LOCATIONS=ABDH,ABDG
LM_TARGET_LOCATIONS=
# Filter gramasi yang ingin dipantau (pisah koma, gunakan titik sebagai desimal).
# Contoh: 0.5,1,2,3  → hanya pantau 0,5 gr, 1 gr, 2 gr, dan 3 gr.
# Kosongkan untuk pantau semua gramasi.
LM_TARGET_WEIGHTS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Kirim notifikasi ke topik terpisah per butik dalam 1 grup (fitur Topics Telegram).
# Syarat: grup harus berupa Supergroup dan fitur Topics diaktifkan.
# Topic per butik akan dibuat otomatis dan disimpan di data/topics.json.
# Jika false, semua notifikasi dikirim ke chat biasa / grup tanpa topik.
TELEGRAM_USE_TOPICS=false
CHECK_INTERVAL_SECONDS=60
# Port untuk status page web (http://server-ip:PORT).
# Buka di browser untuk cek apakah bot masih aktif + snapshot stok terakhir.
# 0 = nonaktifkan status page.
STATUS_PORT=3200
TZ=Asia/Jakarta
HEADLESS=true
LOG_LEVEL=info
DEBUG_SCREENSHOT_ON_ERROR=true

# (Opsional) Token Wit.ai untuk auto-solve reCAPTCHA via audio challenge.
# Buat akun gratis di https://wit.ai → buat app → copy Server Access Token.
# Jika dikosongkan, set HEADLESS=false pada run pertama dan solve CAPTCHA manual.
WIT_AI_ACCESS_TOKEN=
